    {
      "id": 9,
      "type": "timeseries",
      "title": "Battery Voltage",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT created_at AS time, battery_v AS \"Battery Voltage\" FROM sessions WHERE $__timeFilter(created_at) ORDER BY 1",
