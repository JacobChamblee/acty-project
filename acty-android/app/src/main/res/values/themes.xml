<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Light theme for Cactus Insights.
        Navigation/status bars are transparent — Compose owns insets via
        WindowCompat.setDecorFitsSystemWindows(window, false).
    -->
    <style name="Theme.Acty" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cactus_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_light</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Transparent bars — Compose handles insets -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Light icons on light background -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:windowBackground">@color/bg_light</item>
    </style>

    <!-- Splash screen — shows immediately before Compose draws -->
    <style name="Theme.Acty.Splash" parent="Theme.Acty">
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/bg_light</item>
    </style>
</resources>
