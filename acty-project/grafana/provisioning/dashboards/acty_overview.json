  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Vehicle Health Score",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT health_score FROM sessions ORDER BY created_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 80   }
            ]
          },
          "mappings": [],
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Critical Alerts",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT COUNT(*) AS count FROM alerts WHERE session_id = (SELECT id FROM sessions ORDER BY created_at DESC LIMIT 1) AND severity = 'critical'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1    },
              { "color": "red",    "value": 3    }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
