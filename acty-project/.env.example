# Acty — environment configuration
# Copy to .env and fill in values. Never commit .env.

# ── Inference node (4U DIY, RTX 3060, Ubuntu 24.04) ──────────────────────────
OLLAMA_HOST=http://192.168.68.138:11434
OLLAMA_BASE_URL=http://192.168.68.138:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_FAST_MODEL=phi4-mini

# ── API server ─────────────────────────────────────────────────────────────────
ACTY_HOST=0.0.0.0
ACTY_PORT=8765

# ── CSV data directory (where acty_obd_capture.py writes files) ───────────────
ACTY_CSV_DIR=/home/jacob

# ── Anthropic API (for cloud fallback / report generation) ───────────────────
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── OBD dongle ────────────────────────────────────────────────────────────────
# VeePeak OBDCheck BLE — classic BT RFCOMM
OBD_BT_ADDRESS=8C:DE:52:D9:7E:D1
OBD_POLL_INTERVAL=0.5

# ── Privacy / federated learning ─────────────────────────────────────────────
# Differential privacy epsilon budget (lower = more private)
DP_EPSILON=1.0
# Rotating ZK token seed — change periodically
ZK_TOKEN_SEED=changeme-random-string

# ── RAG server (4U) ───────────────────────────────────────────────────────────
RAG_BASE_URL=http://192.168.68.138:8766
