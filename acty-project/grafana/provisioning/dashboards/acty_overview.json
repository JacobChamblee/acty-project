          "rawSql": "SELECT created_at AS time, avg_coolant_c AS \"Avg Coolant\", max_coolant_c AS \"Max Coolant\" FROM sessions WHERE $__timeFilter(created_at) ORDER BY 1",
          "format": "time_series"
        }
