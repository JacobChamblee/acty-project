          "rawQuery": true,
          "rawSql": "SELECT created_at AS time, avg_rpm AS \"Avg RPM\", max_rpm AS \"Max RPM\" FROM sessions WHERE $__timeFilter(created_at) ORDER BY 1",
          "format": "time_series"
