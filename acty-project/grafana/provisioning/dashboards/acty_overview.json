        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Latest Drive",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT CONCAT(session_date::TEXT, ' ', session_time::TEXT) AS latest FROM sessions ORDER BY created_at DESC LIMIT 1",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Health Score Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT created_at AS time, health_score AS \"Health Score\" FROM sessions WHERE $__timeFilter(created_at) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 80   }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "spanNulls": true,
            "showPoints": "auto",
            "pointSize": 6
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "RPM per Drive",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
