          "rawSql": "SELECT created_at AS time, ltft_b1 AS \"LTFT B1\", stft_b1 AS \"STFT B1\" FROM sessions WHERE $__timeFilter(created_at) ORDER BY 1",
          "format": "time_series"
        }
      ],
      "options": {
