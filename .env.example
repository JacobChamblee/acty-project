# ═══════════════════════════════════════════════════════════════════════════════
# Acty Project - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all SECRET_* variables with actual values
# 3. Never commit .env to git (it's in .gitignore)
# 4. Keep .env.example in repo for documentation
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend API Configuration ───────────────────────────────────────────────────
ACTY_HOST=0.0.0.0
ACTY_PORT=8765
ACTY_CSV_DIR=/data
ACTY_MODEL_DIR=/models
ENVIRONMENT=development

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://acty:acty@localhost:5432/acty-postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=acty-postgres
DB_USER=acty
DB_PASSWORD=CHANGE_ME_secure_password_here

# ── Inference Infrastructure (4U DIY Server) ────────────────────────────────────
# Default: local homelab at 192.168.68.138
OLLAMA_HOST=http://192.168.68.138:11434
OLLAMA_BASE_URL=http://192.168.68.138:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_FAST_MODEL=phi4-mini

# ── RAG Server (ChromaDB + LLM inference) ───────────────────────────────────────
RAG_BASE_URL=http://192.168.68.138:8766

# ── Cloud Inference Fallback (Anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-SECRET_API_KEY_HERE

# ── Privacy & Security ──────────────────────────────────────────────────────────
# Differential privacy ε (lower = more privacy, higher = less noise)
DP_EPSILON=1.0

# Zero-knowledge proof token seed (random 32-byte hex)
ZK_TOKEN_SEED=SECRET_32_BYTE_HEX_STRING_HERE

# ── Frontend Configuration ──────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:8765
REACT_APP_ENV=development
PORT=3000

# ── Cloudflare DNS (DDNS Updates) ──────────────────────────────────────────────
CF_ZONE_ID=ZONE_ID_HERE
CF_ACCOUNT_ID=ACCOUNT_ID_HERE
CF_API_TOKEN=SECRET_CLOUDFLARE_TOKEN_HERE
DDNS_UPDATE_INTERVAL=300  # seconds (5 min)

# ── Email / Notifications (Optional) ────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=SECRET_EMAIL@gmail.com
SMTP_PASSWORD=SECRET_APP_PASSWORD_HERE
ALERT_EMAIL=admin@acty-labs.com

# ── Supabase Authentication (Awaiting Provisioning) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=SECRET_SUPABASE_KEY_HERE
SUPABASE_JWT_SECRET=SECRET_JWT_SECRET_HERE

# ── GitHub Integrations (Optional) ──────────────────────────────────────────────
GITHUB_TOKEN=SECRET_GITHUB_TOKEN_HERE
GITHUB_REPO=acty-labs/acty-project

# ═══════════════════════════════════════════════════════════════════════════════
# DOCKER COMPOSE OVERRIDES
# ═══════════════════════════════════════════════════════════════════════════════
# When running: docker compose up -d
# All DATABASE_URL, OLLAMA_*, RAG_* variables are injected from this .env file
# ═════════════════════════════════════════════════════════════════════════════════
