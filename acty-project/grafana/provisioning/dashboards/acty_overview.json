            "showPoints": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "piechart",
      "title": "Alert Severity Distribution",
      "gridPos": { "x": 0, "y": 36, "w": 8, "h": 9 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT severity, COUNT(*) AS count FROM alerts GROUP BY severity ORDER BY severity",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list", "placement": "right", "calcs": ["sum"] },
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "normal" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Recent Alerts",
      "gridPos": { "x": 8, "y": 36, "w": 16, "h": 9 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT created_at AS \"Time\", label AS \"Sensor\", severity AS \"Severity\", ROUND(value::NUMERIC, 2) AS \"Value\", unit AS \"Unit\", message AS \"Message\" FROM alerts ORDER BY created_at DESC LIMIT 100",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Time", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "text": "CRITICAL", "color": "red",    "index": 0 } } },
                  { "type": "value", "options": { "warning":  { "text": "WARN",     "color": "yellow", "index": 1 } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "Sensor" },
            "properties": [{ "id": "custom.width", "value": 160 }]
          },
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [{ "id": "custom.width", "value": 70 }]
          },
          {
            "matcher": { "id": "byName", "options": "Unit" },
            "properties": [{ "id": "custom.width", "value": 55 }]
          }
        ]
      }
    },
    {
      "id": 14,
      "type": "bargauge",
      "title": "Component Health by Target",
      "gridPos": { "x": 0, "y": 45, "w": 8, "h": 10 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT label, ROUND(AVG(health_score) * 100, 1) AS \"Health %\" FROM maintenance_predictions GROUP BY label ORDER BY \"Health %\" ASC",
          "format": "table"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "/Health %/" },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "auto",
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50   },
              { "color": "green",  "value": 80   }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      }
    },
    {
      "id": 15,
      "type": "table",
      "title": "Drive Sessions",
      "gridPos": { "x": 8, "y": 45, "w": 16, "h": 10 },
      "datasource": { "type": "postgres", "uid": "acty-pg" },
      "targets": [
        {
          "refId": "A",
          "rawQuery": true,
          "rawSql": "SELECT session_date AS \"Date\", session_time AS \"Time\", ROUND(duration_min::NUMERIC, 1) AS \"Duration (min)\", sample_count AS \"Samples\", ROUND(avg_rpm::NUMERIC) AS \"Avg RPM\", ROUND(max_speed_kmh::NUMERIC) AS \"Max Speed (km/h)\", ROUND(avg_coolant_c::NUMERIC, 1) AS \"Avg Coolant (°C)\", ROUND(battery_v::NUMERIC, 2) AS \"Battery (V)\", ROUND(pct_time_moving::NUMERIC, 1) AS \"Moving %\", health_score AS \"Health Score\" FROM sessions ORDER BY created_at DESC LIMIT 30",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Date", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "custom": { "align": "center" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health Score" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red",    "value": null },
                    { "color": "yellow", "value": 50   },
                    { "color": "green",  "value": 80   }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Date" },
            "properties": [{ "id": "custom.width", "value": 100 }]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [{ "id": "custom.width", "value": 70 }]
          }
        ]
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["acty", "obd", "automotive"],
  "templating": { "list": [] },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Acty — Vehicle Health",
  "uid": "acty-vehicle-health",
